   "source": [
    "print(\"\\n\" + \"=\"*90)\n",
    "print(\"【Part 4】敏感性定量分析\")\n",
    "print(\"=\"*90)\n",
    "\n",
    "# 定义敏感性指数\ndef sensitivity_index(input_range, output_range):\n",
    "    \"\"\"敏感性指数 = Δoutput / Δinput\"\"\"\n",
    "    return output_range / input_range\n",
    "\n",
    "# 计算各类敏感性指标\nDelta_U = U_scan[-1] - U_scan[0]  # 40 kV\nDelta_T = T_scan[-1] - T_scan[0]  # 480 s\n\nS_U_A = sensitivity_index(Delta_U, C_out_A_volt[0] - C_out_A_volt[-1])\nS_U_B = sensitivity_index(Delta_U, C_out_B_volt[0] - C_out_B_volt[-1])\n\nS_T_A = sensitivity_index(Delta_T, C_out_A_tap[-1] - C_out_A_tap[0])\nS_T_B = sensitivity_index(Delta_T, C_out_B_tap[-1] - C_out_B_tap[0])\n\nprint(\"\\n【表2】敏感性指数对比\")\nprint(f\"{'控制变量':<15s} {'工况A(高浓)':>15s} {'工况B(低浓)':>15s} {'相对差异':>15s}\")\nprint(\"-\" * 65)\nprint(f\"{'电压敏感度':<15s} {S_U_A:>15.4f} {S_U_B:>15.4f} {S_U_A/S_U_B:>14.2f}x\")\nprint(f\"{'(mg/Nm³ per kV)':<15s} {'':>15s} {'':>15s} {'':>15s}\")\nprint(\"-\" * 65)\nprint(f\"{'振打敏感度':<15s} {S_T_A:>15.4f} {S_T_B:>15.4f} {S_T_A/S_T_B:>14.2f}x\")\nprint(f\"{'(mg/Nm³ per s)':<15s} {'':>15s} {'':>15s} {'':>15s}\")\n\nprint(\"\\n\" + \"-\" * 65)\nprint(\"【相对敏感性对比】\")\nprint(\"-\" * 65)\n\n# 计算工况内的电压 vs 振打相对敏感性\nratio_A_U_vs_T = S_U_A / S_T_A  # 电压相对于振打的敏感性倍数\nratio_B_U_vs_T = S_U_B / S_T_B\n\nprint(f\"\\n工况A（高浓度）：\")\nprint(f\"  电压敏感性 / 振打敏感性 = {S_U_A:.4f} / {S_T_A:.4f} = {ratio_A_U_vs_T:.2f}\")\nprint(f\"  说明：电压的控制力是振打的 {ratio_A_U_vs_T:.1f} 倍\")\n\nprint(f\"\\n工况B（低浓度）：\")\nprint(f\"  电压敏感性 / 振打敏感性 = {S_U_B:.4f} / {S_T_B:.4f} = {ratio_B_U_vs_T:.2f}\")\nprint(f\"  说明：电压的控制力是振打的 {ratio_B_U_vs_T:.1f} 倍\")\n\nprint(\"\\n\" + \"=\"*90)\nprint(\"【定量结论】\")\nprint(\"=\"*90)\nprint(f\"\"\"\n1. 【电压敏感性对比】\n   - 工况A（高浓度）：S_U = {S_U_A:.4f} mg/Nm³/kV\n   - 工况B（低浓度）：S_U = {S_U_B:.4f} mg/Nm³/kV\n   - 差异倍数：S_U_A / S_U_B = {S_U_A/S_U_B:.2f}\n   \n   定量说明：\n   高浓度工况中，增加1 kV电压可降低出口浓度 {S_U_A:.4f} mg/Nm³；\n   低浓度工况中，同样增加1 kV电压只能降低 {S_U_B:.4f} mg/Nm³。\n   \n   因此，高浓度工况对电压的敏感性是低浓度工况的 {S_U_A/S_U_B:.1f} 倍，\n   说明在高浓度条件下，\"精细化调压\"的边际效益更高。\n\n2. 【振打敏感性对比】\n   - 工况A（高浓度）：S_T = {S_T_A:.4f} mg/Nm³/s\n   - 工况B（低浓度）：S_T = {S_T_B:.4f} mg/Nm³/s\n   - 差异倍数：S_T_A / S_T_B = {S_T_A/S_T_B:.2f}\n   \n   定量说明：\n   高浓度工况中，延长1秒振打周期导致出口浓度增加 {S_T_A:.4f} mg/Nm³；\n   低浓度工况中，同样延长导致增加 {S_T_B:.4f} mg/Nm³。\n   \n   高浓度工况对振打周期变化的敏感性是低浓度的 {S_T_A/S_T_B:.1f} 倍，\n   说明高浓度工况需要\"更频繁的振打\"来维持达标。\n\n3. 【电压 vs 振打的相对控制力】\n   - 工况A: 电压控制力 / 振打控制力 = {ratio_A_U_vs_T:.2f}\n   - 工况B: 电压控制力 / 振打控制力 = {ratio_B_U_vs_T:.2f}\n   \n   定量说明：\n   在高浓度工况下，电压的控制力约为振打的 {ratio_A_U_vs_T:.1f} 倍;\n   在低浓度工况下，电压的控制力约为振打的 {ratio_B_U_vs_T:.1f} 倍。\n   \n   这说明在所有工况下，\"电压是主导控制变量\"，振打周期是\"辅助变量\"。\n   但两者都不可忽视，需要协同优化。\n\n4. 【绝对控制范围对比】\n   电压范围 [40, 80] kV 可实现出口浓度变化 > 180 mg/Nm³（高浓度）\n   振打范围 [120, 600] s 可实现出口浓度变化 < 60 mg/Nm³（高浓度）\n   \n   说明：电压调节范围的有效控制跨度约 3 倍于振打周期\n\"\"\")\n\n# 绘制敏感性曲线对比\nfig, axes = plt.subplots(1, 2, figsize=(14, 5))\n\n# 电压敏感性曲线\naxes[0].plot(U_scan, C_out_A_volt, 'o-', linewidth=2, markersize=4, label='工况A（高浓度）', color='red')\naxes[0].plot(U_scan, C_out_B_volt, 's-', linewidth=2, markersize=4, label='工况B（低浓度）', color='blue')\naxes[0].axhline(10, color='gray', linestyle='--', alpha=0.5, label='达标值 10 mg/Nm³')\naxes[0].set_xlabel('电压 (kV)', fontsize=11)\naxes[0].set_ylabel('出口浓度 (mg/Nm³)', fontsize=11)\naxes[0].set_title('【实验A结果】电压敏感性曲线对比', fontsize=12, fontweight='bold')\naxes[0].legend(fontsize=10)\naxes[0].grid(alpha=0.3)\n\n# 振打敏感性曲线\naxes[1].plot(T_scan, C_out_A_tap, 'o-', linewidth=2, markersize=4, label='工况A（高浓度）', color='red')\naxes[1].plot(T_scan, C_out_B_tap, 's-', linewidth=2, markersize=4, label='工况B（低浓度）', color='blue')\naxes[1].axhline(10, color='gray', linestyle='--', alpha=0.5, label='达标值 10 mg/Nm³')\naxes[1].set_xlabel('振打周期 (s)', fontsize=11)\naxes[1].set_ylabel('出口浓度 (mg/Nm³)', fontsize=11)\naxes[1].set_title('【实验B结果】振打周期敏感性曲线对比', fontsize=12, fontweight='bold')\naxes[1].legend(fontsize=10)\naxes[1].grid(alpha=0.3)\n\nplt.tight_layout()\nplt.show()\n\nprint(\"\\n(图表已绘制)\")"
